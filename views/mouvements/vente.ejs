<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Nouvelle vente' }) %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">
    <h3 class="mb-4"><i class="fa-solid fa-cart-shopping"></i> Nouvelle vente</h3>

    <% if (error) { %>
      <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="card shadow-sm border-0">
      <div class="card-body">
        <form method="POST" action="/ventes/nouvelle" id="venteForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="mb-3 position-relative">
            <label class="form-label">Produit *</label>
            <input type="text" id="produitSearch" class="form-control" placeholder="Rechercher un produit par nom ou référence..." autocomplete="off" required>
            <input type="hidden" name="produit_id" id="produitId" required>
            <div id="produitSuggestions" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; max-height: 260px; overflow-y: auto;"></div>
            <div class="form-text" id="stockInfo"></div>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">Quantité vendue *</label>
              <input type="number" step="0.01" name="quantite" id="quantite" class="form-control" min="0.01" value="1" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Prix de vente effectif *</label>
              <input type="number" step="0.01" name="prix_vente_effectif" id="prixVente" class="form-control" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Date et heure</label>
              <input type="datetime-local" name="date_mouvement" class="form-control" value="<%= now %>">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Commentaire (optionnel)</label>
            <textarea name="commentaire" class="form-control" rows="2"></textarea>
          </div>

          <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary btn-lg"><i class="fa-solid fa-check"></i> Enregistrer la vente</button>
            <a href="/dashboard" class="btn btn-outline-secondary btn-lg">Annuler</a>
          </div>
        </form>
      </div>
    </div>

    <!-- Liste déroulante classique de repli (accessibilité / sans JS) -->
    <noscript>
      <div class="mt-3">
        <select class="form-select" disabled>
          <% produits.forEach(p => { %>
            <option><%= p.nom %> (stock: <%= p.stock_actuel %>)</option>
          <% }) %>
        </select>
        <p class="text-muted small">Activez JavaScript pour utiliser la sélection de produit.</p>
      </div>
    </noscript>
  </div>

  <%- include('../partials/toast') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/produit-autocomplete.js"></script>
</body>
</html>
