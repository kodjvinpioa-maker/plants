<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: produit && produit.id ? 'Modifier le produit' : 'Nouveau produit' }) %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">
    <h3 class="mb-4">
      <i class="fa-solid fa-box"></i>
      <%= produit && produit.id ? 'Modifier le produit' : 'Nouveau produit' %>
    </h3>

    <% if (error) { %>
      <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="card shadow-sm border-0">
      <div class="card-body">
        <form method="POST" action="<%= produit && produit.id ? '/produits/' + produit.id + '/modifier' : '/produits/nouveau' %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="mb-3">
            <label class="form-label">Référence (unique) *</label>
            <input type="text" name="reference" class="form-control" required value="<%= produit ? produit.reference : '' %>">
          </div>

          <div class="mb-3">
            <label class="form-label">Nom du produit *</label>
            <input type="text" name="nom" class="form-control" required value="<%= produit ? produit.nom : '' %>">
          </div>

          <% if (produit && produit.id) { %>
          <div class="mb-3">
            <label class="form-label">Stock actuel (calculé automatiquement, non modifiable)</label>
            <input type="text" class="form-control" value="<%= produit.stock_actuel !== undefined ? produit.stock_actuel : '—' %>" disabled>
          </div>
          <% } %>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">Seuil d'alerte</label>
              <input type="number" name="seuil_alerte" class="form-control" min="0" value="<%= produit && produit.seuil_alerte != null ? produit.seuil_alerte : 0 %>">
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Prix de vente</label>
              <input type="number" step="0.01" name="prix_vente" class="form-control" value="<%= produit && produit.prix_vente != null ? produit.prix_vente : '' %>">
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Prix d'achat</label>
              <input type="number" step="0.01" name="prix_achat" class="form-control" value="<%= produit && produit.prix_achat != null ? produit.prix_achat : '' %>">
            </div>
          </div>

          <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
            <a href="/produits" class="btn btn-outline-secondary">Annuler</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
