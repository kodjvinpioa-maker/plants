<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Produits' }) %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container-fluid py-4 px-3 px-md-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
      <h3 class="mb-0"><i class="fa-solid fa-box"></i> Produits</h3>
      <% if (currentUser.role === 'admin') { %>
        <a href="/produits/nouveau" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Ajouter un produit</a>
      <% } %>
    </div>

    <!-- Recherche instantanée -->
    <form method="GET" action="/produits" class="mb-3">
      <div class="input-group">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input type="text" name="q" value="<%= q %>" class="form-control" placeholder="Rechercher par nom ou référence..." onchange="this.form.submit()">
        <button type="submit" class="btn btn-outline-secondary">Rechercher</button>
      </div>
    </form>

    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>Référence</th>
              <th>Nom</th>
              <th>Stock actuel</th>
              <th>Seuil d'alerte</th>
              <th>Prix de vente</th>
              <th>Prix d'achat</th>
              <th>Statut</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (produits.length === 0) { %>
              <tr><td colspan="8" class="text-center text-muted py-4">Aucun produit trouvé</td></tr>
            <% } %>
            <% produits.forEach(p => { %>
              <tr class="<%= p.stock_actuel <= p.seuil_alerte ? 'table-danger' : '' %> <%= !p.actif ? 'opacity-50' : '' %>">
                <td><%= p.reference %></td>
                <td><%= p.nom %></td>
                <td>
                  <strong><%= p.stock_actuel %></strong>
                  <% if (p.stock_actuel <= p.seuil_alerte) { %>
                    <i class="fa-solid fa-triangle-exclamation text-danger ms-1" title="Stock en alerte"></i>
                  <% } %>
                </td>
                <td><%= p.seuil_alerte %></td>
                <td><%= p.prix_vente != null ? p.prix_vente.toLocaleString('fr-FR') + ' F' : '—' %></td>
                <td><%= p.prix_achat != null ? p.prix_achat.toLocaleString('fr-FR') + ' F' : '—' %></td>
                <td>
                  <% if (p.actif) { %>
                    <span class="badge bg-success">Actif</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Archivé</span>
                  <% } %>
                </td>
                <td class="text-nowrap">
                  <% if (currentUser.role === 'admin') { %>
                    <a href="/produits/<%= p.id %>/modifier" class="btn btn-sm btn-outline-primary" title="Modifier">
                      <i class="fa-solid fa-pen"></i>
                    </a>
                    <form method="POST" action="/produits/<%= p.id %>/toggle" class="d-inline" onsubmit="return confirm('Confirmer ce changement de statut ?');">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-sm btn-outline-secondary" title="<%= p.actif ? 'Archiver' : 'Réactiver' %>">
                        <i class="fa-solid <%= p.actif ? 'fa-box-archive' : 'fa-rotate-left' %>"></i>
                      </button>
                    </form>
                  <% } else { %>
                    <span class="text-muted small">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
