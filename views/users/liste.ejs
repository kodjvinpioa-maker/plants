<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Utilisateurs' }) %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
      <h3 class="mb-0"><i class="fa-solid fa-users"></i> Utilisateurs</h3>
      <a href="/users/nouveau" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Créer un collaborateur</a>
    </div>

    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr><th>Email</th><th>Rôle</th><th>Créé le</th></tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td><%= u.email %></td>
                <td>
                  <% if (u.role === 'admin') { %>
                    <span class="badge bg-dark">Admin</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Collaborateur</span>
                  <% } %>
                </td>
                <td class="small text-muted"><%= new Date(u.created_at).toLocaleString('fr-FR') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
