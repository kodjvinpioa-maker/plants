<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Nouveau collaborateur' }) %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">
    <h3 class="mb-4"><i class="fa-solid fa-user-plus"></i> Créer un compte collaborateur</h3>

    <% if (error) { %>
      <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="card shadow-sm border-0">
      <div class="card-body">
        <form method="POST" action="/users/nouveau">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="mb-3">
            <label class="form-label">Email *</label>
            <input type="email" name="email" class="form-control" required placeholder="collaborateur@example.com">
          </div>

          <div class="mb-3">
            <label class="form-label">Mot de passe temporaire *</label>
            <input type="text" name="password" class="form-control" required minlength="6" placeholder="Minimum 6 caractères">
          </div>

          <div class="mb-3">
            <label class="form-label">Rôle</label>
            <select name="role" class="form-select">
              <option value="collaborateur" selected>Collaborateur</option>
              <option value="admin">Admin</option>
            </select>
          </div>

          <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Créer le compte</button>
            <a href="/users" class="btn btn-outline-secondary">Annuler</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
