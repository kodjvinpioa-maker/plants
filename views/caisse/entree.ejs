<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Entrée de caisse' }) %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">
    <h3 class="mb-4 text-success"><i class="fa-solid fa-plus"></i> Ajouter une entrée de caisse</h3>

    <% if (error) { %>
      <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="card shadow-sm border-0">
      <div class="card-body">
        <form method="POST" action="/caisse/entree">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="mb-3">
            <label class="form-label">Motif *</label>
            <input type="text" name="motif" class="form-control" required placeholder="Ex : apport de fonds">
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Montant (F) *</label>
              <input type="number" step="0.01" name="montant" class="form-control" min="0.01" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Date et heure</label>
              <input type="datetime-local" name="date_mouvement" class="form-control" value="<%= now %>">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Commentaire (optionnel)</label>
            <textarea name="commentaire" class="form-control" rows="2"></textarea>
          </div>

          <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-success btn-lg"><i class="fa-solid fa-check"></i> Enregistrer</button>
            <a href="/caisse" class="btn btn-outline-secondary btn-lg">Annuler</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
