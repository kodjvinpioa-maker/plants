<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Petite caisse' }) %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">
    <h3 class="mb-4"><i class="fa-solid fa-money-bill"></i> Petite caisse</h3>

    <!-- Solde bien visible -->
    <div class="card shadow-sm border-0 mb-4 <%= solde >= 0 ? 'bg-success-subtle' : 'bg-danger-subtle' %>">
      <div class="card-body text-center py-4">
        <div class="text-muted">Solde actuel de la caisse</div>
        <div class="display-4 fw-bold <%= solde >= 0 ? 'text-success' : 'text-danger' %>">
          <%= solde.toLocaleString('fr-FR') %> F
        </div>
        <div class="d-flex justify-content-center gap-4 mt-2 small text-muted">
          <span><i class="fa-solid fa-arrow-down text-success"></i> Entrées : <%= totalEntrees.toLocaleString('fr-FR') %> F</span>
          <span><i class="fa-solid fa-arrow-up text-danger"></i> Sorties : <%= totalSorties.toLocaleString('fr-FR') %> F</span>
        </div>
      </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
      <a href="/caisse/entree" class="btn btn-success btn-lg flex-fill"><i class="fa-solid fa-plus"></i> Ajouter une entrée</a>
      <a href="/caisse/sortie" class="btn btn-danger btn-lg flex-fill"><i class="fa-solid fa-minus"></i> Ajouter une sortie</a>
      <a href="/caisse/historique" class="btn btn-outline-secondary btn-lg flex-fill"><i class="fa-solid fa-clock-rotate-left"></i> Voir l'historique complet</a>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-header bg-white">Derniers mouvements</div>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr><th>Type</th><th>Motif</th><th>Montant</th><th>Date</th><th>Utilisateur</th><th></th></tr>
          </thead>
          <tbody>
            <% if (derniersMouvements.length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted py-4">Aucun mouvement enregistré</td></tr>
            <% } %>
            <% derniersMouvements.forEach(m => { %>
              <tr>
                <td>
                  <% if (m.type === 'entree') { %>
                    <span class="badge bg-success">Entrée</span>
                  <% } else { %>
                    <span class="badge bg-danger">Sortie</span>
                  <% } %>
                </td>
                <td><%= m.motif %></td>
                <td><%= m.montant.toLocaleString('fr-FR') %> F</td>
                <td class="small"><%= new Date(m.date_mouvement).toLocaleString('fr-FR') %></td>
                <td class="small"><%= m.user_email || '—' %></td>
                <td><% if (m.est_lie_vente) { %><span class="badge bg-info text-dark">Vente</span><% } %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
